# ─── apps/web (Next.js) ────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Sign in with Google via Supabase social OAuth. Defaults true (the
# button renders). Set to "false" while Supabase's Google provider is
# still off — hides the button so users can't trigger a 400 dead-end.
# See docs/supabase-google-oauth-setup.md.
NEXT_PUBLIC_SUPABASE_GOOGLE_ENABLED=true
# Booking day window for the slot picker (FR-TH-15). Defaults 9 / 21.
NEXT_PUBLIC_BOOKING_DAY_START_HOUR=9
NEXT_PUBLIC_BOOKING_DAY_END_HOUR=21

# ─── apps/api (NestJS) ─────────────────────────────────────────────────────
PORT=3001
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/peerahat?schema=public
REDIS_URL=redis://localhost:6379

# Supabase (server-side JWT validation)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Object storage (KYC + sheets, NFR-03 private bucket)
S3_ENDPOINT=
S3_REGION=
S3_BUCKET_KYC=
S3_BUCKET_KYC_ARCHIVE=
S3_BUCKET_SHEETS=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Payments — manual PromptPay + ZercleSlip verification (FR-PM-01..07).
# Auto-payment gateways (Stripe Connect / Opn Payments) are off the roadmap;
# see requirements.md §4.5. ZERCLE_SLIP_ENABLED=false sends every slip
# straight to the admin "รออนุมัติ" queue for human review.
ZERCLE_SLIP_ENABLED=false
ZERCLE_SLIP_API_KEY=
ZERCLE_SLIP_API_URL=
ZERCLE_PLATFORM_ACCOUNT_NUMBER=
PROMPTPAY_MERCHANT_ID=

# Payout math (FR-PM-04 / FR-PM-07). Validated at startup; commission +
# withholding must sum to < 100. Flat rates — no tiers.
PLATFORM_COMMISSION_PCT=10
WITHHOLDING_TAX_PCT=3

# Notifications
RESEND_API_KEY=
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# Postpone refund-split percentages (FR-TH-11). Defaults 50 / 10 / 40
# (tutor / platform / student). Validated at startup — tutor + platform
# must sum to ≤ 100.
POSTPONE_TUTOR_CUT_SHORT_NOTICE=50
POSTPONE_PLATFORM_FEE_SHORT_NOTICE=10

# Set JOBS_ENABLED=false to skip BullMQ workers (used by openapi:export
# and any run without Redis attached). Defaults to enabled.
JOBS_ENABLED=

# FR-TH-17: per-tutor Google OAuth. Each tutor connects their own
# personal Gmail (no Workspace required) and the platform stores an
# encrypted refresh_token. Meet links are minted on the tutor's
# calendar inline at payment-confirm. See docs/google-oauth-setup.md
# for the OAuth client + consent-screen walkthrough.
#
# Without these set, /auth/google/connect throws a 400 — the tutor
# can't connect and they stay invisible in /tutors search. The rest
# of the platform keeps working.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/google/callback
# 32-byte AES-256 key, base64 — encrypts tutor refresh tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GOOGLE_TOKEN_ENCRYPTION_KEY=
# High-entropy secret for the state JWT round-tripped through Google.
GOOGLE_OAUTH_STATE_JWT_SECRET=

# Observability
SENTRY_DSN=
