// Prisma schema for Pee Rahat — Phase 1 MVP.
// All persistent state lives here; apps/web never touches the DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity ──────────────────────────────────────────────────────────────

enum UserRole {
  student
  tutor
  parent
  admin
}

model User {
  id          String   @id @default(uuid())
  supabaseId  String   @unique
  email       String   @unique
  displayName String
  role        UserRole @default(student)
  avatarUrl   String?
  createdAt   DateTime @default(now())

  tutorProfile              TutorProfile?
  studentProfile            StudentProfile?
  kycSubmissions            KycSubmission[]
  bookingsAsStudent         Booking[]         @relation("StudentBookings")
  reviews                   TutorReview[]
  posts                     CommunityPost[]
  replies                   CommunityReply[]
  upvotes                   PostUpvote[]
  reports                   Report[]
  paymentIntents            PaymentIntent[]
  sentMessages              ChatMessage[]
  threadsAsStudent          ChatThread[]      @relation("StudentChat")
  loginAuditLogs            LoginAuditLog[]
  adminAuditLogs            AdminAuditLog[]   @relation("AdminAuditLogs")
  postponeRequestsInitiated PostponeRequest[]
}

model StudentProfile {
  userId        String    @id
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolGrade   String?
  pdpaConsentAt DateTime?
}

// ─── Tutors & KYC ──────────────────────────────────────────────────────────

enum KycStatus {
  not_started
  pending
  verified
  rejected
}

model TutorProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String
  university    String
  faculty       String
  hourlyRate    Int
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  defectCount   Int      @default(0)
  introVideoUrl String?
  isVerified    Boolean  @default(false)
  subjects      String[]
  createdAt     DateTime @default(now())

  // FR-TH-17: each tutor connects their own Google account via OAuth2;
  // the platform holds an encrypted refresh_token and mints Meet links on
  // their calendar at payment-confirm. googleRefreshToken IS NOT NULL is
  // a hard search-visibility gate — tutors without Google connected do
  // not appear in /tutors search results.
  googleRefreshToken String?
  googleEmail        String?
  googleConnectedAt  DateTime?

  // FR-TH-02 / FR-PM-06: bank account for manual PromptPay payouts.
  // Mirrored from the latest verified KycSubmission on admin approve so
  // PayoutsService can read it without a KYC join. bankAccountNumber is
  // AES-256-GCM encrypted; only last-4 digits appear in non-admin API
  // responses. bankAccountNumber IS NOT NULL is a search-visibility gate
  // alongside googleRefreshToken — tutors who can't be paid don't appear
  // in search.
  passbookObjectKey String?
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  bankUpdatedAt     DateTime?

  bookings       Booking[]
  reviews        TutorReview[]
  sheets         StudySheet[]
  threads        ChatThread[] @relation("TutorChat")
  payouts        Payout[]
  unavailability TutorUnavailability[]

  @@index([university])
  @@index([rating])
}

// FR-TH-16: tutor-marked weekly busy windows (lunch breaks, recurring
// commitments, etc.). Expanded into concrete intervals by the busy
// endpoint and the overlap guard.
model TutorUnavailability {
  id          String       @id @default(uuid())
  tutorId     String
  tutor       TutorProfile @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  weekday     Int          // 0=Sun … 6=Sat (matches JS Date.getDay)
  startMinute Int          // minutes since local midnight, 0..1440
  endMinute   Int          // strictly greater than startMinute
  reason      String?
  createdAt   DateTime     @default(now())

  @@index([tutorId])
}

model KycSubmission {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  idPhotoKey      String
  selfieKey       String
  transcriptKey   String
  // FR-TH-02: the legal name on the tutor's National ID. User types it
  // during onboarding (admin verifies against the ID photo at review).
  // bankAccountName must match this string (normalized) — payouts get
  // bounced if the name on the slip differs from the name on the ID.
  idName          String?
  // FR-TH-02 / FR-PM-06: passbook + bank info captured during onboarding.
  // Copied to TutorProfile on admin approval so payouts read without a
  // KycSubmission join. bankAccountNumber is AES-256-GCM encrypted at
  // rest via CryptoService — only the last 4 digits ever appear in
  // API responses outside the admin reveal endpoint.
  passbookObjectKey String?
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  status          KycStatus @default(pending)
  rejectionReason String?
  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
  archivedAt      DateTime? // moved to cold storage (NFR-03)

  @@index([status])
}

// ─── Bookings ──────────────────────────────────────────────────────────────

enum BookingStatus {
  requested
  accepted
  rejected
  expired
  paid
  completed
  reported
  refunded
  cancelled
  postpone_pending
  postponed
  cancelled_no_agreement
  cancelled_tutor_unresponsive
  cancelled_tutor_initiated
}

model Booking {
  id                 String           @id @default(uuid())
  studentId          String
  student            User             @relation("StudentBookings", fields: [studentId], references: [id])
  tutorId            String
  tutor              TutorProfile     @relation(fields: [tutorId], references: [id])
  subject            String
  status             BookingStatus    @default(requested)
  scheduledAt        DateTime
  durationMinutes    Int
  amountThb          Int
  acceptDeadlineAt   DateTime
  reportWindowEndsAt DateTime?
  postponeRequestId  String?          @unique
  postponeRequest    PostponeRequest? @relation(fields: [postponeRequestId], references: [id])

  // FR-TH-17: auto-generated Google Meet link. Created inline at payment-
  // confirm on the tutor's own calendar via their connected Google account.
  // Cleared on postpone-confirm so the cloned booking regenerates fresh.
  // Admin can force-regenerate via POST /admin/bookings/:id/regenerate-meet.
  meetingUrl            String?
  googleCalendarEventId String?

  createdAt          DateTime         @default(now())

  paymentIntent PaymentIntent?
  review        TutorReview?
  chatThread    ChatThread?
  refundLedgers RefundLedger[]

  @@index([tutorId, status])
  @@index([studentId, status])
}

model TutorReview {
  id        String       @id @default(uuid())
  bookingId String       @unique
  booking   Booking      @relation(fields: [bookingId], references: [id])
  studentId String
  student   User         @relation(fields: [studentId], references: [id])
  tutorId   String
  tutor     TutorProfile @relation(fields: [tutorId], references: [id])
  rating    Int
  text      String
  createdAt DateTime     @default(now())

  @@index([tutorId])
}

// ─── Sheet Marketplace ────────────────────────────────────────────────────

model StudySheet {
  id                     String       @id @default(uuid())
  sellerId               String
  seller                 TutorProfile @relation(fields: [sellerId], references: [id])
  title                  String
  description            String
  subject                String
  priceThb               Int
  rating                 Float        @default(0)
  reviewCount            Int          @default(0)
  pdfObjectKey           String
  previewImageObjectKeys String[]
  introVideoUrl          String?
  pageCount              Int          @default(0)
  isSuspended            Boolean      @default(false)
  createdAt              DateTime     @default(now())

  paymentIntents PaymentIntent[]

  @@index([subject])
  @@index([sellerId])
}

// ─── TCAS ──────────────────────────────────────────────────────────────────

enum TcasRoundKey {
  r1_portfolio
  r2_quota_kku_netsat
  r3_admission
  r4_direct
}

model TcasProgram {
  id            String   @id @default(uuid())

  university    String
  campus        String?
  faculty       String
  major         String
  subTrack      String?
  courseCode    String?
  programType   String?

  round         TcasRoundKey
  admissionYear Int
  quotaSeats    Int      @default(0)

  components    Json
  totalMinScore Float?

  tags          String[]
  sourceUrl     String?
  sourceFile    String?
  importedAt    DateTime?
  importedBy    String?

  pastStats     TcasProgramStat[]

  @@unique([university, major, subTrack, programType, round, admissionYear], name: "tcas_program_identity")
  @@index([round, admissionYear])
  @@index([courseCode])
}

model TcasProgramStat {
  id            String   @id @default(uuid())
  programId     String?
  program       TcasProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)

  courseCode    String
  university    String
  campus        String?              // วิทยาเขต — main vs satellite
  faculty       String
  major         String
  subTrack      String?              // สาขา/วิชาเอก — specialization within a program
  jointCode     String?              // รหัสรับร่วม — CUPT joint-admission group key
  year          Int
  round         TcasRoundKey

  // CUPT sometimes publishes rows with no quota (aggregated description rows
  // or programs without a published cap). Treat both as nullable so the
  // importer doesn't reject them — admin can filter at preview time.
  quotaSeats    Int?                 // รับ
  applicants    Int?                 // สมัคร
  // Pass counts are nullable because the TCAS68 r3_1 layout publishes only
  // one "ผ่าน" column (no round-1/round-2 split). For that layout we store
  // the value in passedRound1 and leave passedRound2 null.
  // Float (not Int) because CUPT occasionally publishes fractional values
  // and our row 2899 audit found at least one row where CUPT shifted a
  // score into this column ("41.1709"); we accept what they ship.
  passedRound1  Float?
  passedRound2  Float?

  maxScoreR1    Float?
  minScoreR1    Float?
  maxScoreR2    Float?
  minScoreR2    Float?

  sourceFile    String?
  importedAt    DateTime @default(now())

  @@unique([courseCode, year, round])
  @@index([year, round])
  @@index([programId])
}

model TcasImportAudit {
  id         String   @id @default(uuid())
  kind       String   // "criteria" | "stats"
  filename   String
  fileHash   String?
  inserted   Int      @default(0)
  updated    Int      @default(0)
  skipped    Int      @default(0)
  importedBy String?
  importedAt DateTime @default(now())

  @@index([importedAt])
}

model TcasDeadline {
  id    String   @id @default(uuid())
  title String
  date  DateTime
  type  String
}

// ─── Quiz ──────────────────────────────────────────────────────────────────

model QuizQuestion {
  id           String   @id @default(uuid())
  subject      String
  topic        String
  question     String
  options      String[]
  correctIndex Int

  @@index([subject])
}

model QuizSubmission {
  id         String   @id @default(uuid())
  userId     String
  subject    String
  scorePct   Float
  weakTopics String[]
  createdAt  DateTime @default(now())
}

// ─── Community ─────────────────────────────────────────────────────────────

model CommunityPost {
  id          String   @id @default(uuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  title       String
  content     String
  upvoteCount Int      @default(0)
  isHidden    Boolean  @default(false)
  createdAt   DateTime @default(now())

  replies CommunityReply[]
  upvotes PostUpvote[]

  @@index([createdAt])
}

model CommunityReply {
  id        String        @id @default(uuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime      @default(now())

  @@index([postId])
}

model PostUpvote {
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())

  @@id([postId, userId])
}

// ─── Reports & moderation ─────────────────────────────────────────────────

enum ReportTargetType {
  post
  reply
  sheet
  tutor
  message
  booking
}

model Report {
  id         String           @id @default(uuid())
  reporterId String
  reporter   User             @relation(fields: [reporterId], references: [id])
  targetType ReportTargetType
  targetId   String
  reason     String
  details    String
  resolvedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([targetType, targetId])
}

// ─── Payments & Escrow ─────────────────────────────────────────────────────

enum PaymentItemType {
  booking
  sheet
}

enum PaymentStatus {
  pending_transfer
  slip_uploaded
  verifying
  // `verified` is deprecated — kept in the enum because Postgres cannot
  // drop enum values. No code path emits it; treat occurrences as data
  // that predates the manual-flow refactor.
  verified
  held_in_escrow
  released_for_payout // class done + report window passed; queued for next batch
  paid_out            // admin marked the manual PromptPay transfer to tutor done
  refunded
  failed
  disputed
  partially_refunded
}

enum PayoutStatus {
  pending     // queued for next batch
  in_progress // admin is processing
  completed   // money sent to tutor
  failed      // tutor account issue, etc.
}

model PaymentIntent {
  id                 String          @id @default(uuid())
  payerId            String
  payer              User            @relation(fields: [payerId], references: [id])
  itemType           PaymentItemType
  bookingId          String?         @unique
  booking            Booking?        @relation(fields: [bookingId], references: [id])
  sheetId            String?
  sheet              StudySheet?     @relation(fields: [sheetId], references: [id])
  amountThb          Int
  // FR-TH-11: pre-refund snapshot. Refunds shrink amountThb in place so
  // the payout batch picks up the surviving tutor portion unchanged;
  // originalAmountThb keeps the audit trail of what the student paid.
  originalAmountThb  Int?
  promptPayQrPayload String
  status             PaymentStatus   @default(pending_transfer)
  slipObjectKey      String?
  slipUploadedAt     DateTime?
  // FR-PM-02: ZercleSlip verification audit trail.
  // - transactionId is the bank transaction ref off the slip — used to
  //   block duplicate-slip submissions (one slip ≠ two paid bookings).
  // - zercleResponse is the full Zercle payload (sender, recipient,
  //   transferDate, raw OCR) for admin review and PDPA-friendly audit.
  transactionId      String?         @unique
  zercleResponse     Json?
  zercleVerifiedAt   DateTime?
  verifiedAmountThb  Int?
  failureReason      String?
  expiresAt          DateTime
  releasedAt         DateTime?
  payoutId           String?
  payout             Payout?         @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  refundLedgers      RefundLedger[]
  createdAt          DateTime        @default(now())

  @@index([payoutId])
}

model Payout {
  id                String       @id @default(uuid())
  tutorId           String
  tutor             TutorProfile @relation(fields: [tutorId], references: [id])
  periodStart       DateTime
  periodEnd         DateTime
  grossThb          Int
  commissionThb     Int
  withholdingTaxThb Int
  netThb            Int
  scheduledAt       DateTime
  // FR-PM-06: admin-confirmed manual transfer tracking.
  status            PayoutStatus @default(pending)
  transferredAt     DateTime?
  transferredBy     String?      // admin User.id who confirmed the transfer
  transferSlipKey   String?      // R2/S3 object key for admin's transfer-proof slip
  notes             String?
  // Retained for the data already on disk; new flow uses transferredAt.
  // mark-transferred sets both for one release cycle of overlap.
  paidAt            DateTime?

  intents PaymentIntent[]
}

// ─── Chat ──────────────────────────────────────────────────────────────────

model ChatThread {
  id                String       @id @default(uuid())
  studentId         String
  student           User         @relation("StudentChat", fields: [studentId], references: [id])
  tutorId           String
  tutor             TutorProfile @relation("TutorChat", fields: [tutorId], references: [id])
  bookingId         String?      @unique
  booking           Booking?     @relation(fields: [bookingId], references: [id])
  studentLastReadAt DateTime?
  tutorLastReadAt   DateTime?
  closedAt          DateTime?
  createdAt         DateTime     @default(now())

  messages ChatMessage[]

  @@unique([studentId, tutorId])
}

model ChatMessage {
  id        String          @id @default(uuid())
  threadId  String
  thread    ChatThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User            @relation(fields: [authorId], references: [id])
  body      String
  kind      ChatMessageKind @default(user)
  redacted  Boolean         @default(false)
  createdAt DateTime        @default(now())

  @@index([threadId, createdAt])
}

enum ChatMessageKind {
  user
  system
}

// ─── Audit log (NFR-05) ────────────────────────────────────────────────────

model LoginAuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ip        String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// PDPA / Computer Crime Act: admin-side audit trail for sensitive
// surfaces (passbook view, bank reveal, etc.). Distinct from LoginAuditLog
// so the action / target columns can be queried directly without parsing
// userAgent strings. NFR-05 retention applies.
model AdminAuditLog {
  id         String   @id @default(uuid())
  adminId    String
  admin      User     @relation("AdminAuditLogs", fields: [adminId], references: [id])
  action     String   // e.g. "view_passbook"
  targetType String   // "tutor" | "kyc" | "payout"
  targetId   String
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}

// ─── Postpone-class negotiation (FR-TH-10..14) ────────────────────────────

enum PostponeInitiator {
  student
  tutor
}

enum PostponeStatus {
  negotiating
  agreed
  expired
}

enum PostponeOutcome {
  agreed
  no_agreement
  unresponsive
  tutor_initiated_no_agreement
}

model PostponeRequest {
  id               String            @id @default(uuid())
  booking          Booking?
  initiatorId      String
  initiator        User              @relation(fields: [initiatorId], references: [id])
  initiatorRole    PostponeInitiator
  reason           String
  chatExpiresAt    DateTime
  status           PostponeStatus    @default(negotiating)
  proposedAt       DateTime?
  proposedDuration Int?
  resolvedAt       DateTime?
  resolvedAs       PostponeOutcome?
  wasShortNotice   Boolean
  createdAt        DateTime          @default(now())

  @@index([status, chatExpiresAt])
}

enum RefundReason {
  postpone_short_notice_no_agreement
  postpone_unresponsive
  postpone_tutor_initiated_no_agreement
  admin_manual
}

model RefundLedger {
  id                String        @id @default(uuid())
  paymentIntentId   String
  paymentIntent     PaymentIntent @relation(fields: [paymentIntentId], references: [id])
  bookingId         String
  booking           Booking       @relation(fields: [bookingId], references: [id])
  originalAmountThb Int
  studentRefundThb  Int
  tutorThb          Int
  platformThb       Int
  reasonCode        RefundReason
  createdAt         DateTime      @default(now())

  @@index([bookingId])
  @@index([paymentIntentId])
}
